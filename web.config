<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>

    <!-- default.aspx served via ASP.NET handler — works on UNC shares
         where IUSR has no access but the app pool identity does -->
    <defaultDocument enabled="true">
      <files>
        <clear/>
        <add value="default.aspx"/>
      </files>
    </defaultDocument>

    <!-- No caching on the status page -->
    <httpProtocol>
      <customHeaders>
        <add name="Cache-Control" value="no-store"/>
        <add name="X-Content-Type-Options" value="nosniff"/>
      </customHeaders>
    </httpProtocol>

    <!-- Block direct browser access to config.json -->
    <security>
      <authorization>
        <allow users="*"/>
      </authorization>
      <requestFiltering>
        <denyUrlSequences>
          <add sequence="config.json"/>
        </denyUrlSequences>
      </requestFiltering>
    </security>

  </system.webServer>
</configuration>
