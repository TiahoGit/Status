<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <system.web>
    <!-- Suppress X-AspNet-Version header -->
    <httpRuntime enableVersionHeader="false" />
  </system.web>

  <system.webServer>

    <!-- default.aspx served via ASP.NET handler — works on UNC shares
         where IUSR has no access but the app pool identity does -->
    <defaultDocument enabled="true">
      <files>
        <clear/>
        <add value="default.aspx"/>
      </files>
    </defaultDocument>

    <!-- Suppress IIS and ASP.NET version disclosure headers -->
    <httpProtocol>
      <customHeaders>
        <add name="Cache-Control" value="no-store"/>
        <add name="X-Content-Type-Options" value="nosniff"/>
        <remove name="X-Powered-By"/>
      </customHeaders>
    </httpProtocol>

    <!-- Block direct browser access to config.json (first layer) -->
    <security>
      <authorization>
        <allow users="*"/>
      </authorization>
      <requestFiltering removeServerHeader="true">
        <denyUrlSequences>
          <add sequence="config.json"/>
        </denyUrlSequences>
      </requestFiltering>
    </security>

  </system.webServer>

  <!-- Block config.json at the authorization level (second layer) -->
  <location path="config.json">
    <system.webServer>
      <security>
        <authorization>
          <deny users="*"/>
        </authorization>
      </security>
    </system.webServer>
  </location>

</configuration>
